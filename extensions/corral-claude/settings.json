{
  "//": "corral-claude hooks. Merge the `hooks` block into ~/.claude/settings.json (user scope) or .claude/settings.json (project scope). Replace ABSOLUTE_PATH with the absolute path to this directory. Requires `bun` on PATH. See README.md.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [{ "type": "command", "command": "bun", "args": ["ABSOLUTE_PATH/hook.ts"] }]
      }
    ],
    "SessionEnd": [
      { "hooks": [{ "type": "command", "command": "bun", "args": ["ABSOLUTE_PATH/hook.ts"], "timeout": 5 }] }
    ],
    "UserPromptSubmit": [
      { "hooks": [{ "type": "command", "command": "bun", "args": ["ABSOLUTE_PATH/hook.ts"] }] }
    ],
    "PreToolUse": [
      { "matcher": "*", "hooks": [{ "type": "command", "command": "bun", "args": ["ABSOLUTE_PATH/hook.ts"] }] }
    ],
    "PostToolUse": [
      { "matcher": "*", "hooks": [{ "type": "command", "command": "bun", "args": ["ABSOLUTE_PATH/hook.ts"] }] }
    ],
    "Notification": [
      { "hooks": [{ "type": "command", "command": "bun", "args": ["ABSOLUTE_PATH/hook.ts"] }] }
    ],
    "Stop": [
      { "hooks": [{ "type": "command", "command": "bun", "args": ["ABSOLUTE_PATH/hook.ts"] }] },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun",
            "args": ["ABSOLUTE_PATH/hook.ts", "await"],
            "async": true,
            "asyncRewake": true,
            "timeout": 360
          }
        ]
      }
    ]
  }
}
